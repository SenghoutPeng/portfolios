# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real tokens.

# GitHub personal access token used by app/api/github/contributions/route.ts
# Create one at https://github.com/settings/tokens (fine-grained or classic,
# needs read:user + public repo read access — no write scopes required).
GITHUB_TOKEN=

# GitHub username to fetch stats for.
GITHUB_LOGIN=SenghoutPeng
